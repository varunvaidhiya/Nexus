# Copy to .env and fill in. Compose reads this file automatically.

# --- Database (required) ---
POSTGRES_PASSWORD=change-me
# POSTGRES_USER=nexus
# POSTGRES_DB=nexus
# POSTGRES_PORT=5432

# --- API ---
# NEXUS_ENVIRONMENT=prod          # dev | prod (log format)
# NEXUS_LOG_LEVEL=INFO
# NEXUS_API_PORT=8000

# --- Web ---
# Where the browser reaches the API. Baked into the client bundle at build
# time — rebuild the web image after changing it.
# NEXT_PUBLIC_API_URL=http://localhost:8000
# The origin the API allows for CORS (where you open the web UI).
# NEXUS_WEB_ORIGIN=http://localhost:3000
# NEXUS_WEB_PORT=3000
