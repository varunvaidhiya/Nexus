# Copy to .env and fill in. Compose reads this file automatically.

# --- Database (required) ---
POSTGRES_PASSWORD=change-me
# POSTGRES_USER=nexus
# POSTGRES_DB=nexus
# POSTGRES_PORT=5432

# --- API ---
# Encrypts provider API keys at rest (required to store keys). 64 hex chars.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Keep it out of the database and back it up separately — losing it means
# re-entering your provider keys.
NEXUS_MASTER_KEY=
# Bearer token gating the whole API (the web UI asks for it on login).
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
NEXUS_AUTH_TOKEN=
# NEXUS_ENVIRONMENT=prod          # dev | prod (log format)
# NEXUS_LOG_LEVEL=INFO
# NEXUS_API_PORT=8000

# --- Web ---
# Where the browser reaches the API. Baked into the client bundle at build
# time — rebuild the web image after changing it.
# NEXT_PUBLIC_API_URL=http://localhost:8000
# The origin the API allows for CORS (where you open the web UI).
# NEXUS_WEB_ORIGIN=http://localhost:3000
# NEXUS_WEB_PORT=3000
